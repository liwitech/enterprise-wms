# ─────────────────────────────────────────────────────────────────
# Enterprise WMS - Production Environment Variables
# Copy this file to .env.production and fill in real values
# NEVER commit .env.production to version control
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string (via PgBouncer in production)
DATABASE_URL=postgresql+asyncpg://ewms:CHANGE_ME@pgbouncer:5432/ewms_db

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=ewms
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=ewms_db

# ── Redis ─────────────────────────────────────────────────────────
# Redis connection string (include password if REDIS_PASSWORD is set)
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Security ──────────────────────────────────────────────────────
# JWT secret key - generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# JWT algorithm (keep as HS256 unless you need RS256)
ALGORITHM=HS256

# Access token lifetime in minutes (480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────
# Allowed origins for browser requests (JSON array as string)
# Replace with your actual domain
CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ── Application ───────────────────────────────────────────────────
PROJECT_NAME=Enterprise Work Management System
VERSION=1.0.0
API_PREFIX=/api

# ── Frontend ──────────────────────────────────────────────────────
# API URL that the frontend browser uses to reach the backend
# In production with nginx proxy, this should be your domain
VITE_API_URL=https://yourdomain.com
VITE_APP_NAME=Enterprise Work Management System

# ── PgBouncer ─────────────────────────────────────────────────────
# These are automatically set from POSTGRES_* vars in docker-compose.prod.yml
# No need to set separately unless running PgBouncer standalone

# ── Monitoring ────────────────────────────────────────────────────
# Grafana admin credentials (only needed if running Grafana via docker-compose)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# Prometheus scrape interval (default: 15s)
# PROMETHEUS_SCRAPE_INTERVAL=15s
